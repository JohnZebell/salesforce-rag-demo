# n8n webhook backing the RAG agent.
# Server-side only — deliberately NOT prefixed with NEXT_PUBLIC_, so the URL
# never ships in the client bundle where it could be scraped and called directly.
N8N_WEBHOOK_URL=https://n8n.nutricove.co/webhook/salesforce-rag

# Optional rate-limit tuning (defaults shown).
RATE_LIMIT_MAX=15
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_COOLDOWN_MS=10000
